    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "^5.4.3",
    "typescript-eslint": "^8.0.0"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "fastify": "^5.7.4"
